rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---
    
    // Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Check if user is the owner of the document
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    // Check if user has admin privileges
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'diagnost'] ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.pgmd == 100);
    }

    // Check if the requesting user (Google) has linked the target user (Telegram)
    // The Google User's doc must have 'telegram_id' == targetUserId
    function isLinked(targetUserId) {
        return isAuthenticated() && 
               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.telegram_id == targetUserId;
    }

    // --- Rules ---

    // 1. Users Collection
    match /users/{userId} {
      // Owner can read/write
      // Linked user (Google) can READ Telegram user data
      allow read: if isOwner(userId) || isLinked(userId) || isAdmin();
      
      // Write:
      // 1. Owner can write.
      // 2. We allow setting 'claimant_uid' (handshake step 1) - covered by isOwner.
      // 3. We allow setting 'telegram_id' (handshake step 2) on OUR OWN doc, 
      //    IF the target telegram doc has 'claimant_uid' == our uid.
      allow write: if isOwner(userId);
      
      // Update rule to strictly control 'telegram_id' modification could be added here for extra security,
      // but 'isOwner' is generally sufficient if we trust the client logic to do the handshake.
      // For stricter server-side enforcement, we would check request.resource.data.telegram_id against external verification,
      // which is hard in Rules alone without the handshake data.
      
      // Calculations Subcollection
      match /calculations/{calcId} {
        allow read: if isOwner(userId) || isLinked(userId) || isAdmin();
        allow write: if isOwner(userId) || isAdmin();
      }
    }
    
    // 2. Games Collection
    match /situation_packs/{packId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    match /games/{gameId} {
      allow read: if isAuthenticated();
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || 
                    (isAuthenticated() && resource.data.situation.controllerId == request.auth.uid);
      
      match /participants/{participantId} {
        allow create, update: if isOwner(participantId) || isAdmin();
        allow read: if isAuthenticated(); 
      }
      
      match /answers/{answerId} {
        allow create: if isAuthenticated(); 
        allow read: if isAdmin(); 
      }
    }
    
    // 3. Requests Collection
    match /requests/{requestId} {
      allow create: if isAuthenticated();
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAdmin(); 
      // User can cancel (delete)?
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
  }
}
