rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---
    
    // Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Check if user is the owner of the document
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    // Check if user has admin privileges
    // Requires 'role': 'admin' or 'diagnost' field in the user document
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'diagnost']);
    }

    // --- Rules ---

    // 1. Users Collection
    match /users/{userId} {
      // Users can read/write their own profile
      allow read, write: if isOwner(userId);
      
      // Admins can read all users (needed for Host Panel to see names)
      allow read: if isAdmin(); 

      // Calculations Subcollection
      match /calculations/{calcId} {
        allow read, write: if isOwner(userId);
      }
    }
    
    // 2. Games Collection
    match /games/{gameId} {
      // Anyone authenticated can read games (to see the list)
      allow read: if isAuthenticated();
      
      // Only Admins can create or update Game details
      allow create, update, delete: if isAdmin();
      
      // Participants Subcollection
      match /participants/{participantId} {
        // User joining (creating their own doc)
        allow create: if isOwner(participantId);
        
        // User updating their role
        allow update: if isOwner(participantId);
        
        // Admin approving participant
        allow update: if isAdmin();
        
        // Everyone in the game needs to see participants (Host Panel + potentially other players)
        allow read: if isAuthenticated(); 
      }
      
      // Answers Subcollection (Legacy)
      match /answers/{answerId} {
        allow create: if isAuthenticated(); 
        allow read: if isAdmin(); 
      }
    }
    
    // 3. Requests Collection (Support/Bonus)
    match /requests/{requestId} {
      allow create: if isAuthenticated();
      // Users see their own requests, Admins see all
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAdmin(); 
    }
  }
}
