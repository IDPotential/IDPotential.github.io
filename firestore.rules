rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---
    
    // Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Check if user is the owner of the document
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    // Check if user has admin privileges
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'diagnost'] ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.pgmd == 100);
    }

    // Check if the requesting user (Google) has linked the target user (Telegram)
    // The Google User's doc must have 'telegram_id' == targetUserId
    function isLinked(targetUserId) {
        return isAuthenticated() && 
               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.telegram_id == targetUserId;
    }

    // --- Rules ---

    // 1. Users Collection
    match /users/{userId} {
      // Owner can read/write
      // Linked user (Google) can READ Telegram user data
      allow read: if isOwner(userId) || isLinked(userId) || isAdmin();
      
      // Write:
      // 1. Owner can write.
      // 2. We allow setting 'claimant_uid' (handshake step 1) - covered by isOwner.
      // 3. We allow setting 'telegram_id' (handshake step 2) on OUR OWN doc, 
      //    IF the target telegram doc has 'claimant_uid' == our uid.
      allow write: if isOwner(userId) || isAdmin();
      
      // Update rule to strictly control 'telegram_id' modification could be added here for extra security,
      // but 'isOwner' is generally sufficient if we trust the client logic to do the handshake.
      // For stricter server-side enforcement, we would check request.resource.data.telegram_id against external verification,
      // which is hard in Rules alone without the handshake data.
      
      // Calculation Subcollection
      match /calculations/{calcId} {
        allow read: if isOwner(userId) || isLinked(userId) || isAdmin();
        allow write: if isOwner(userId) || isAdmin();
      }

      // Training Stats (New)
      match /training_stats/{dateId} {
         allow read, write: if isOwner(userId) || isAdmin();
      }

      // Game History Subcollection
      // Path: users/{uid}/game_history/{gameId}/rounds/{roundId}
      match /game_history/{gameId} {
         allow read: if isOwner(userId) || isAdmin();
         allow write: if isOwner(userId) || isAdmin() || 
                      (isAuthenticated() && get(/databases/$(database)/documents/games/$(gameId)).data.hostId == request.auth.uid);
         
         match /rounds/{roundId} {
            allow read: if isOwner(userId) || isAdmin();
            allow write: if isAdmin() || 
                         (isAuthenticated() && get(/databases/$(database)/documents/games/$(gameId)).data.hostId == request.auth.uid);
         }
      }
    }
    
    // --- Helper Functions (Game Context) ---
    
    // Check if user is the Host of the game
    function isHost(gameId) {
       return isAuthenticated() && 
              get(/databases/$(database)/documents/games/$(gameId)).data.hostId == request.auth.uid;
    }

    // Check if user is the Controller of the situation
    function isController(gameId) {
       // Note: Safely accessing nested fields in rules checks existence implicitly or returns error/false
       // We check if controllerId matches. 
       return isAuthenticated() && 
              get(/databases/$(database)/documents/games/$(gameId)).data.situation.controllerId == request.auth.uid;
    }

    // 2. Games Collection
    match /situation_packs/{packId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    match /games/{gameId} {
      allow read: if isAuthenticated();
      
      // Create: Admin or Diagnost (checked via function)
      allow create: if isAdmin();
      
      // Delete: Admin OR Host (Owner of the game)
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.hostId == request.auth.uid);
      
      // Update: Admin OR Host OR Controller
      // Note: We use resource.data (existing doc) to check Host, because request.resource (new doc) might change it? 
      // Usually Host doesn't change hostId.
      allow update: if isAdmin() || isHost(gameId) || isController(gameId);
      
      match /participants/{participantId} {
        // Read: Any auth user
        allow read: if isAuthenticated(); 
        
        // Write (Create/Update/Delete): 
        // 1. Owner (Player themselves)
        // 2. Admin
        // 3. Host (Manage game)
        // 4. Controller (Manage game flow)
        allow write: if isOwner(participantId) || isAdmin() || isHost(gameId) || isController(gameId);
      }
      
      match /answers/{answerId} {
        allow create: if isAuthenticated(); 
        allow read: if isAdmin(); 
      }

      match /rounds/{roundId} {
         allow read: if isAuthenticated();
         allow write: if isAdmin() || isHost(gameId) || isController(gameId);
      }
    }
    
    // 3. Requests Collection
    match /requests/{requestId} {
      allow create: if isAuthenticated();
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAdmin(); 
      // User can cancel (delete)?
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // 4. Festival Applications
    match /festival_applications/{appId} {
      allow create: if true; // Allow public applications (userId can be null)
      allow read, update: if isAdmin();
    }
  }
}
